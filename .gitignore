# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/
.playwright-mcp/

# next.js
/.next/
/out/
.turbo/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.swp
*.swo
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files — never commit. Vercel injects real values at runtime.
.env
.env*.local
.env.development
.env.production
.env.staging
.env*

# vercel-local state (generated by `vercel link`)
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ad-hoc scratch
/tmp/
# Ignore .claude/ contents but keep project-scoped skills — they should ship
# with the repo for collaborators and CI agents. Note: must use `.claude/*`
# (not `.claude/`) so the parent dir is not excluded; gitignore can't re-add
# children of an excluded directory.
.claude/*
!.claude/skills/
/data/audit/

# SQLite snapshots — never commit binary backups.
*.bak
data/*.bak

# --- Explicitly DO include the SQLite DB ----------------------------------
# It is the data payload of the dashboard. Override any broader rule that
# might drop it.
!data/federal_ai_inventory_2025.db
